# ── MotherDuck ────────────────────────────────────────────────────────────────
# Get your token from: https://app.motherduck.com/settings/tokens
MOTHERDUCK_TOKEN=your_motherduck_token_here

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Get your key from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Slack (optional) ─────────────────────────────────────────────────────────
# Leave blank to skip Slack alerts — the pipeline still runs and all incidents
# are stored in MotherDuck and visible in the Streamlit dashboard.
# To enable: create an Incoming Webhook at https://api.slack.com/apps
SLACK_WEBHOOK_URL=

# ── dbt target (dev | prod) ───────────────────────────────────────────────────
# dev  → local DuckDB file at /tmp/dq_monitor.duckdb
# prod → MotherDuck cloud warehouse
DBT_TARGET=dev

# ── Airflow ───────────────────────────────────────────────────────────────────
# Needed by Docker to set correct file permissions on mounted volumes
AIRFLOW_UID=50000
