# ── MotherDuck ────────────────────────────────────────────────────────────────
# Get your token from: https://app.motherduck.com/settings/tokens
MOTHERDUCK_TOKEN=your_motherduck_token_here

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Get your key from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Slack ─────────────────────────────────────────────────────────────────────
# Create an Incoming Webhook at: https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── dbt target (dev | prod) ───────────────────────────────────────────────────
# dev  → local DuckDB file at /tmp/dq_monitor.duckdb
# prod → MotherDuck cloud warehouse
DBT_TARGET=dev

# ── Airflow ───────────────────────────────────────────────────────────────────
# Needed by Docker to set correct file permissions on mounted volumes
AIRFLOW_UID=50000
